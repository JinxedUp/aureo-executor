<Window x:Class="RblxExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RblxExecutorUI"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Aureo"
        Width="1080"
        Height="660"
        MinWidth="920"
        MinHeight="560"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="10" Background="{StaticResource WindowGradient}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" CornerRadius="12" ClipToBounds="True" SnapsToDevicePixels="True">
        <Border.Effect>
            <StaticResource ResourceKey="WindowShadow"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgElevated}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="12,0,8,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M9.8132 15.9038L9 18.75L8.1868 15.9038C7.75968 14.4089 6.59112 13.2403 5.09619 12.8132L2.25 12L5.09619 11.1868C6.59113 10.7597 7.75968 9.59112 8.1868 8.09619L9 5.25L9.8132 8.09619C10.2403 9.59113 11.4089 10.7597 12.9038 11.1868L15.75 12L12.9038 12.8132C11.4089 13.2403 10.2403 14.4089 9.8132 15.9038Z" Fill="{StaticResource GoldBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="Aureo" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <RadioButton x:Name="TopTabEditor" Style="{StaticResource TopNavTab}" IsChecked="True" Checked="Tab_Editor">
                            <TextBlock Text="Editor" FontSize="12" FontWeight="SemiBold"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TopNavTab}" Checked="Tab_ScriptHub">
                            <TextBlock Text="Scripts" FontSize="12" FontWeight="SemiBold"/>
                        </RadioButton>
                        <RadioButton x:Name="TopTabHub" Style="{StaticResource TopNavTab}" Checked="Tab_Hub">
                            <TextBlock Text="Hub" FontSize="12" FontWeight="SemiBold"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TopNavTab}" Checked="Tab_Clients">
                            <TextBlock Text="Clients" FontSize="12" FontWeight="SemiBold"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource TopNavTab}" Margin="0" Checked="Tab_Settings">
                            <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold"/>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowCommandButton}" Content="_" Click="Minimize_Click" FontSize="14" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource WindowCommandButton}" Click="MaximizeRestore_Click" ToolTip="Maximize / Restore" Margin="0,0,4,0">
                            <Path Data="M5.25 5.25H18.75V18.75H5.25V5.25Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Width="12"
                                  Height="12"/>
                        </Button>
                        <Button Style="{StaticResource WindowCommandButton}" Click="Close_Click" ToolTip="Close">
                            <Path Data="M6 18L18 6M6 6L18 18"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Width="12"
                                  Height="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10,10,10,8">
                <Grid x:Name="ViewEditor">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorder}" CornerRadius="10,10,0,0" BorderThickness="1,1,1,0" Padding="8,6">
                        <Grid x:Name="EditorTabsHeaderGrid" SizeChanged="EditorTabsHeaderGrid_SizeChanged">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="EditorTabsColumn" Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ListBox x:Name="EditorTabsList"
                                     Grid.Column="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="False"
                                     Loaded="EditorTabsList_Loaded"
                                     PreviewMouseWheel="EditorTabsList_PreviewMouseWheel"
                                     SelectionChanged="EditorTabsList_SelectionChanged"
                                     ItemsSource="{Binding EditorTabs}"
                                     SelectedItem="{Binding SelectedEditorTab, Mode=TwoWay}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,6,0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="TabFrame" Style="{StaticResource DocTab}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="TabFrame" Property="Background" Value="#23262D"/>
                                                            <Setter TargetName="TabFrame" Property="BorderBrush" Value="#6B5739"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="TabFrame" Property="Background" Value="#1E2127"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:EditorTabItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19.5 14.25V11.625C19.5 9.76104 17.989 8.25 16.125 8.25H14.625C14.0037 8.25 13.5 7.74632 13.5 7.125V5.625C13.5 3.76104 11.989 2.25 10.125 2.25H8.25M8.25 15H15.75M8.25 18H12M10.5 2.25H5.625C5.00368 2.25 4.5 2.75368 4.5 3.375V20.625C4.5 21.2463 5.00368 21.75 5.625 21.75H18.375C18.9963 21.75 19.5 21.2463 19.5 20.625V11.25C19.5 6.27944 15.4706 2.25 10.5 2.25Z"
                                                  Stroke="{StaticResource TextMuted}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="14"
                                                  Height="14"
                                                  Margin="0,0,7,0"/>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                            <Button Style="{StaticResource IconButton}"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="8,0,0,0"
                                                    Click="CloseEditorTab_Click"
                                                    Tag="{Binding}">
                                                <Path Data="M6 18L18 6M6 6L18 18"
                                                      Stroke="{StaticResource TextMuted}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Stretch="Uniform"
                                                      Width="10"
                                                      Height="10"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button x:Name="AddTabButton" Grid.Column="1" Style="{StaticResource IconButton}" ToolTip="New Tab" Click="AddEditorTab_Click">
                                <Path Data="M12 4.5V19.5M19.5 12L4.5 12"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform"
                                      Width="14"
                                      Height="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" CornerRadius="0,0,10,10" Padding="0" Background="#0E1015">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3A3125" Offset="0"/>
                                <GradientStop Color="#2B313C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <avalonEdit:TextEditor Name="Editor"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas, Courier New"
                                               FontSize="15"
                                               Background="Transparent"
                                               Foreground="{StaticResource TextPrimary}"
                                               ShowLineNumbers="True"
                                               LineNumbersForeground="{StaticResource TextMuted}"
                                               WordWrap="False"
                                               HorizontalScrollBarVisibility="Auto"
                                               VerticalScrollBarVisibility="Auto"
                                               TextChanged="Editor_TextChanged"
                                               Padding="12,10,12,10"/>
                    </Border>
                </Grid>

                <Grid x:Name="ViewScriptHub" Visibility="Collapsed" Opacity="0">
                    <ScrollViewer x:Name="ScriptHubScrollViewer" VerticalScrollBarVisibility="Auto" ScrollChanged="ScriptHubScrollViewer_ScrollChanged">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScriptHubSearchBox"
                                         Style="{StaticResource SearchBox}"
                                         VerticalAlignment="Center"
                                         TextChanged="ScriptHubSearchBox_TextChanged"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButton}"
                                        Margin="10,0,0,0"
                                        MinWidth="0"
                                        Click="RefreshScriptHub_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M16.0228 9.34841H21.0154V9.34663M2.98413 19.6444V14.6517M2.98413 14.6517L7.97677 14.6517M2.98413 14.6517L6.16502 17.8347C7.15555 18.8271 8.41261 19.58 9.86436 19.969C14.2654 21.1483 18.7892 18.5364 19.9685 14.1353M4.03073 9.86484C5.21 5.46374 9.73377 2.85194 14.1349 4.03121C15.5866 4.4202 16.8437 5.17312 17.8342 6.1655L21.0154 9.34663M21.0154 4.3558V9.34663"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Uniform"
                                              Width="12"
                                              Height="12"
                                              Margin="0,0,8,0"/>
                                        <TextBlock Text="Refresh"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="Script Hub" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Powered by Rscripts.net" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="ScriptHubList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ScriptCard}" MinHeight="258" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="ScriptHubCard_Click">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="120"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" CornerRadius="8" Background="#171B22" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" ClipToBounds="True">
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Row="1" Margin="0,10,0,8">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="40"/>
                                                    <TextBlock Text="{Binding Meta}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Border Style="{StaticResource ScriptBadge}" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding KeyBadge}" Style="{StaticResource ScriptBadgeText}"/>
                                                        </Border>
                                                        <Border Style="{StaticResource ScriptBadge}" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding AccessBadge}" Style="{StaticResource ScriptBadgeText}"/>
                                                        </Border>
                                                        <Border Style="{StaticResource ScriptBadge}">
                                                            <TextBlock Text="{Binding TrustBadge}" Style="{StaticResource ScriptBadgeText}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Style="{StaticResource ScriptHubPrimaryButton}" Click="ExecuteScriptHub_Click" Tag="{Binding}" Margin="0,0,6,0" ToolTip="Execute Script">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Path Style="{StaticResource ButtonGlyphFill}" Data="M5.25 5.653C5.25 4.797 6.167 4.255 6.917 4.667L18.458 11.014C19.235 11.442 19.235 12.558 18.458 12.986L6.917 19.333C6.167 19.745 5.25 19.203 5.25 18.347V5.653" Margin="0,0,6,0"/>
                                                            <TextBlock Text="Run"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="1" Style="{StaticResource ScriptHubActionButton}" Click="CopyScriptHub_Click" Tag="{Binding}" Margin="0,0,6,0" ToolTip="Copy Script">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Path Style="{StaticResource ButtonGlyphStroke}" Data="M15.75 17.25V20.625C15.75 21.246 15.246 21.75 14.625 21.75H4.875C4.254 21.75 3.75 21.246 3.75 20.625V7.875C3.75 7.254 4.254 6.75 4.875 6.75H6.75C7.261 6.75 7.762 6.793 8.25 6.874M15.75 17.25H19.125C19.746 17.25 20.25 16.746 20.25 16.125V11.25C20.25 6.791 17.007 3.089 12.75 2.374C12.262 2.293 11.761 2.25 11.25 2.25H9.375C8.754 2.25 8.25 2.754 8.25 3.375V6.874M15.75 17.25H9.375C8.754 17.25 8.25 16.746 8.25 16.125V6.874M20.25 13.5V11.625C20.25 9.761 18.739 8.25 16.875 8.25H15.375C14.754 8.25 14.25 7.746 14.25 7.125V5.625C14.25 3.761 12.739 2.25 10.875 2.25H9.75" Margin="0,0,6,0"/>
                                                            <TextBlock Text="Copy"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="2" Style="{StaticResource ScriptHubActionButton}" Click="DeleteScriptHub_Click" Tag="{Binding}" Margin="0" ToolTip="Load in Editor">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Path Style="{StaticResource ButtonGlyphStroke}" Data="M3 16.5V18.75C3 19.993 4.007 21 5.25 21H18.75C19.993 21 21 19.993 21 18.75V16.5M16.5 12L12 16.5M12 16.5L7.5 12M12 16.5V3" Margin="0,0,6,0"/>
                                                            <TextBlock Text="Load"/>
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="ScriptHubLoadingText" Text="" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ViewHub" Visibility="Collapsed" Opacity="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="Hub" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="Quick in-game utilities grouped by category." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,12"/>

                            <Border x:Name="HubLockedCard" Style="{StaticResource SettingsCard}" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Attach Required" Style="{StaticResource SettingsSectionTitle}"/>
                                    <TextBlock Text="Attach to Roblox first to unlock Hub tools." Style="{StaticResource SettingsSectionHint}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="HubToolsCard" Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource HubCategoryCard}" Margin="0,0,10,12">
                                            <StackPanel>
                                                <TextBlock Text="Movement" Style="{StaticResource SettingsSectionTitle}"/>
                                                <TextBlock Text="Traversal and mobility toggles." Style="{StaticResource SettingsSectionHint}" Margin="0,4,0,10"/>
                                                <CheckBox x:Name="HubNoclipToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Noclip" Margin="0,0,0,8" Checked="HubNoclip_Checked" Unchecked="HubNoclip_Unchecked"/>
                                                <CheckBox x:Name="HubFlyToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Fly" Margin="0,0,0,8" Checked="HubFly_Checked" Unchecked="HubFly_Unchecked"/>
                                                <CheckBox x:Name="HubInfiniteJumpToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Infinite Jump" Margin="0,0,0,8" Checked="HubInfiniteJump_Checked" Unchecked="HubInfiniteJump_Unchecked"/>
                                                <CheckBox x:Name="HubSpeedToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Speed" Checked="HubSpeed_Checked" Unchecked="HubSpeed_Unchecked"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource HubCategoryCard}" Margin="10,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Player" Style="{StaticResource SettingsSectionTitle}"/>
                                                <TextBlock Text="Character safety and utility tools." Style="{StaticResource SettingsSectionHint}" Margin="0,4,0,10"/>
                                                <CheckBox x:Name="HubAntiAfkToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Anti-AFK" Margin="0,0,0,8" Checked="HubAntiAfk_Checked" Unchecked="HubAntiAfk_Unchecked"/>
                                                <CheckBox x:Name="HubGodModeToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="God Mode" Margin="0,0,0,10" Checked="HubGodMode_Checked" Unchecked="HubGodMode_Unchecked"/>
                                                <Button Style="{StaticResource HubToolActionButton}" Content="Reset Character" Margin="0" Click="HubReset_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource HubCategoryCard}" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Visual" Style="{StaticResource SettingsSectionTitle}"/>
                                                <TextBlock Text="Client-side view helpers." Style="{StaticResource SettingsSectionHint}" Margin="0,4,0,10"/>
                                                <CheckBox x:Name="HubFullbrightToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Fullbright" Margin="0,0,0,8" Checked="HubFullbright_Checked" Unchecked="HubFullbright_Unchecked"/>
                                                <CheckBox x:Name="HubEspToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="ESP" Checked="HubEsp_Checked" Unchecked="HubEsp_Unchecked"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource HubCategoryCard}" Margin="10,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Misc" Style="{StaticResource SettingsSectionTitle}"/>
                                                <TextBlock Text="Extra utilities." Style="{StaticResource SettingsSectionHint}" Margin="0,4,0,10"/>
                                                <CheckBox x:Name="HubClickTpToggle" Style="{StaticResource ToggleSwitchCheckBox}" Content="Click TP (LeftAlt + Click)" Margin="0,0,0,10" Checked="HubClickTp_Checked" Unchecked="HubClickTp_Unchecked"/>
                                                <Button Style="{StaticResource HubToolActionButton}" Content="Run Infinite Yield" Margin="0" Click="HubInfiniteYield_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ViewClients" Visibility="Collapsed" Opacity="0">
                    <Border Style="{StaticResource PanelBorder}" Padding="18" MaxWidth="420" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Client Session" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Border Width="84" Height="84" CornerRadius="42" Background="#1A1E25" Margin="0,0,0,14" ClipToBounds="True" BorderBrush="#53462F" BorderThickness="1">
                                <Image x:Name="ClientAvatarImage" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock x:Name="ClientAccountName" Text="Not Connected" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="ClientPidText" Text="PID: None | Place: Unknown" Margin="0,4,0,12" Foreground="{StaticResource TextMuted}"/>
                            <Border x:Name="ClientBadgeBg" Background="#2A2318" BorderBrush="#6B5738" BorderThickness="1" CornerRadius="16" Padding="10,6" HorizontalAlignment="Left">
                                <TextBlock x:Name="ClientStatusBadge" Text="NOT ATTACHED" Foreground="{StaticResource GoldBrush}" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="ViewSettings" Visibility="Collapsed" Opacity="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Stretch">
                            <TextBlock Text="Settings" Foreground="{StaticResource TextPrimary}" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Configure editor, runtime, and quality-of-life behavior for Aureo." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,14"/>

                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsValueChip}" Margin="0,0,12,0" Padding="14,10">
                                    <StackPanel>
                                        <TextBlock Text="Editor Font" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                        <TextBlock x:Name="SettingsEditorFontPreviewText" Text="JetBrains Mono" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingsValueChip}" Margin="0,0,0,0" Padding="14,10">
                                    <StackPanel>
                                        <TextBlock Text="Tab Width" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                        <TextBlock x:Name="TabSizeValueText" Text="4 Spaces" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SettingsCard}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonGlyphStroke}"
                                                  Stroke="{StaticResource GoldBrush}"
                                                  Data="M4.5 7.5H19.5M4.5 12H19.5M4.5 16.5H14.25"/>
                                            <TextBlock Text="Editor Experience" Style="{StaticResource SettingsSectionTitle}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="Visual polish and typing behavior for the script editor." Style="{StaticResource SettingsSectionHint}" Margin="0,6,0,12"/>

                                        <CheckBox x:Name="WordWrapToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Word Wrap"
                                                  Margin="0,0,0,10"
                                                  Checked="WordWrap_Checked"
                                                  Unchecked="WordWrap_Unchecked"/>
                                        <CheckBox x:Name="LineNumbersToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Line Numbers"
                                                  Margin="0,0,0,10"
                                                  Checked="LineNumbers_Checked"
                                                  Unchecked="LineNumbers_Unchecked"/>
                                        <CheckBox x:Name="HighlightCurrentLineToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Highlight Current Line"
                                                  Margin="0,0,0,10"
                                                  Checked="HighlightCurrentLine_Checked"
                                                  Unchecked="HighlightCurrentLine_Unchecked"/>
                                        <CheckBox x:Name="ShowWhitespaceToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Show Whitespace"
                                                  Margin="0,0,0,10"
                                                  Checked="ShowWhitespace_Checked"
                                                  Unchecked="ShowWhitespace_Unchecked"/>
                                        <CheckBox x:Name="ConvertTabsToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Convert Tabs To Spaces"
                                                  Margin="0,0,0,10"
                                                  Checked="ConvertTabs_Checked"
                                                  Unchecked="ConvertTabs_Unchecked"/>
                                        <CheckBox x:Name="ScrollPastEndToggle"
                                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                                  Content="Scroll Past End Of File"
                                                  Margin="0,0,0,14"
                                                  Checked="ScrollPastEnd_Checked"
                                                  Unchecked="ScrollPastEnd_Unchecked"/>

                                        <TextBlock Text="Font Family" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="EditorFontFamilyCombo"
                                                  Style="{StaticResource SettingsComboBox}"
                                                  Height="34"
                                                  Margin="0,0,0,14"
                                                  SelectionChanged="EditorFontFamilyCombo_SelectionChanged">
                                            <ComboBoxItem Content="JetBrains Mono"/>
                                            <ComboBoxItem Content="Consolas"/>
                                            <ComboBoxItem Content="Courier New"/>
                                            <ComboBoxItem Content="Lucida Console"/>
                                            <ComboBoxItem Content="Fira Code"/>
                                            <ComboBoxItem Content="Segoe UI"/>
                                            <ComboBoxItem Content="Georgia"/>
                                            <ComboBoxItem Content="Trebuchet MS"/>
                                        </ComboBox>

                                        <TextBlock Text="Font Size" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="EditorFontSizeSlider"
                                                    Minimum="12"
                                                    Maximum="24"
                                                    Value="15"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="EditorFontSizeSlider_ValueChanged"/>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsValueChip}" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="EditorFontSizeValueText"
                                                           Text="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Tab Size" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="TabSizeSlider"
                                                    Minimum="2"
                                                    Maximum="8"
                                                    Value="4"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="TabSizeSlider_ValueChanged"/>
                                            <Border Grid.Column="1" Style="{StaticResource SettingsValueChip}" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TabSizeInlineValueText"
                                                           Text="4"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonGlyphStroke}"
                                                      Stroke="{StaticResource GoldBrush}"
                                                      Data="M16.5 10.5V6.75A4.5 4.5 0 0 0 7.5 6.75V10.5M6.75 21H17.25A2.25 2.25 0 0 0 19.5 18.75V12.75A2.25 2.25 0 0 0 17.25 10.5H6.75A2.25 2.25 0 0 0 4.5 12.75V18.75A2.25 2.25 0 0 0 6.75 21Z"/>
                                                <TextBlock Text="Runtime Behavior" Style="{StaticResource SettingsSectionTitle}" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="Connection and process safety controls." Style="{StaticResource SettingsSectionHint}" Margin="0,6,0,12"/>

                                            <CheckBox x:Name="AutoAttachToggle"
                                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                                      Content="Auto Attach"
                                                      Margin="0,0,0,10"
                                                      Checked="AutoAttach_Checked"
                                                      Unchecked="AutoAttach_Unchecked"/>
                                            <CheckBox x:Name="ConfirmKillToggle"
                                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                                      Content="Confirm Before Kill"
                                                      Margin="0,0,0,10"
                                                      Checked="ConfirmKill_Checked"
                                                      Unchecked="ConfirmKill_Unchecked"/>
                                            <CheckBox x:Name="AutoRefreshScriptHubToggle"
                                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                                      Content="Auto Refresh ScriptHub On Open"
                                                      Margin="0,0,0,10"
                                                      Checked="AutoRefreshScriptHub_Checked"
                                                      Unchecked="AutoRefreshScriptHub_Unchecked"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonGlyphStroke}"
                                                      Stroke="{StaticResource GoldBrush}"
                                                      Data="M4.5 12A7.5 7.5 0 1 1 19.5 12A7.5 7.5 0 1 1 4.5 12ZM12 8.25V12.75M12 15.75H12.008V15.758H12V15.75Z"/>
                                                <TextBlock Text="Quality Of Life" Style="{StaticResource SettingsSectionTitle}" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="Comfort and diagnostics toggles for day-to-day use." Style="{StaticResource SettingsSectionHint}" Margin="0,6,0,12"/>

                                            <CheckBox x:Name="ShowNotificationsToggle"
                                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                                      Content="Popup Notifications"
                                                      Margin="0,0,0,10"
                                                      Checked="ShowNotifications_Checked"
                                                      Unchecked="ShowNotifications_Unchecked"/>
                                            <CheckBox x:Name="DebugConsoleToggle"
                                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                                      Content="Debug Console"
                                                      Margin="0,0,0,10"
                                                      Checked="ToggleConsole_Checked"
                                                      Unchecked="ToggleConsole_Unchecked"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource BgElevated}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12" Padding="10,0">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#D0B07E" Offset="0"/>
                                    <GradientStop Color="#896C43" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="InjectionStatus" Text="NOT ATTACHED" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ExecuteMainButton" Style="{StaticResource PrimaryActionButton}" Click="Execute_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphFill}" Data="M5.25 5.653C5.25 4.797 6.167 4.255 6.917 4.667L18.458 11.014C19.235 11.442 19.235 12.558 18.458 12.986L6.917 19.333C6.167 19.745 5.25 19.203 5.25 18.347V5.653" Margin="0,0,8,0"/>
                                <TextBlock Text="Execute" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActionButton}" Click="Clear_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphStroke}" Data="M12 9.75L14.25 12M14.25 12L16.5 14.25M14.25 12L16.5 9.75M14.25 12L12 14.25M9.421 19.171L3.046 12.796C2.606 12.356 2.606 11.644 3.046 11.204L9.421 4.83C9.631 4.619 9.918 4.5 10.216 4.5H19.5C20.743 4.5 21.75 5.507 21.75 6.75V17.25C21.75 18.493 20.743 19.5 19.5 19.5H10.216C9.918 19.5 9.631 19.381 9.421 19.171Z" Margin="0,0,8,0"/>
                                <TextBlock Text="Clear"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActionButton}" Click="Open_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphStroke}" Data="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75H19.5A2.25 2.25 0 0 1 21.75 12V12.75M2.25 12.75 3.051 18.359C3.208 19.457 4.148 20.25 5.258 20.25H18.742C19.852 20.25 20.792 19.457 20.949 18.359L21.75 12.75M2.25 12.75V6.375C2.25 5.132 3.257 4.125 4.5 4.125H8.379C8.777 4.125 9.159 4.283 9.44 4.565L11.56 6.685C11.842 6.967 12.223 7.125 12.621 7.125H19.5C20.743 7.125 21.75 8.132 21.75 9.375V12.75" Margin="0,0,8,0"/>
                                <TextBlock Text="Open Script"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActionButton}" Click="Save_Click" Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphStroke}" Data="M19.5 14.25V11.625C19.5 9.761 17.989 8.25 16.125 8.25H14.625C14.004 8.25 13.5 7.746 13.5 7.125V5.625C13.5 3.761 11.989 2.25 10.125 2.25H8.25M8.25 15H15.75M8.25 18H12M10.5 2.25H5.625C5.004 2.25 4.5 2.754 4.5 3.375V20.625C4.5 21.246 5.004 21.75 5.625 21.75H18.375C18.996 21.75 19.5 21.246 19.5 20.625V11.25C19.5 6.279 15.471 2.25 10.5 2.25Z" Margin="0,0,8,0"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="KillMainButton" Style="{StaticResource DangerActionButton}" Click="KillRoblox_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphStroke}" Data="M9.75 9.75L14.25 14.25M14.25 9.75L9.75 14.25M21 12C21 16.971 16.971 21 12 21C7.029 21 3 16.971 3 12C3 7.029 7.029 3 12 3C16.971 3 21 7.029 21 12Z" Margin="0,0,8,0"/>
                                <TextBlock Text="Kill"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="AttachMainButton" Style="{StaticResource AccentOutlineButton}" Click="Attach_Click" Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonGlyphStroke}" Data="M13.19 8.688C13.639 8.903 14.06 9.196 14.432 9.568C16.189 11.325 16.189 14.175 14.432 15.932L9.932 20.432C8.175 22.189 5.325 22.189 3.568 20.432C1.811 18.675 1.811 15.825 3.568 14.068L5.325 12.311M18.675 11.689L20.432 9.932C22.189 8.175 22.189 5.325 20.432 3.568C18.675 1.811 15.825 1.811 14.068 3.568L9.568 8.068C7.811 9.825 7.811 12.675 9.568 14.432C9.94 14.804 10.361 15.097 10.81 15.312" Margin="0,0,8,0"/>
                                <TextBlock Text="Attach"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid x:Name="ScriptDetailsOverlay" Grid.RowSpan="3" Visibility="Collapsed" Background="#8A0B1119" Panel.ZIndex="98">
                <Border Width="760" Height="580" MaxHeight="760" Background="{StaticResource BgElevated}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" CornerRadius="12" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ScriptDetailsTitleText" Text="Script Title" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ScriptDetailsMetaText" Grid.Row="1" Text="meta" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>
                        <TextBlock x:Name="ScriptDetailsBadgesText" Grid.Row="2" Text="" Foreground="{StaticResource GoldBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        <TextBlock x:Name="ScriptDetailsDescriptionText" Grid.Row="3" Text="description" Foreground="{StaticResource TextPrimary}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,10"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsValueChip}" Padding="10" Margin="0,0,0,10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ScriptDetailsPreviewText"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextMuted}"
                                           TextWrapping="Wrap"
                                           Text="Loading..."/>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource PrimaryActionButton}" Margin="0,0,8,0" Click="ScriptDetailsExecute_Click">
                                <TextBlock Text="Execute"/>
                            </Button>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="ScriptDetailsCopy_Click">
                                <TextBlock Text="Copy"/>
                            </Button>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="ScriptDetailsLoad_Click">
                                <TextBlock Text="Load In Editor"/>
                            </Button>
                            <Button Style="{StaticResource DangerActionButton}" Margin="0" Click="CloseScriptDetails_Click">
                                <TextBlock Text="Close"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Canvas HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,18,62" Panel.ZIndex="100">
                <Border x:Name="NotificationBox" Background="{StaticResource BgElevated}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1" CornerRadius="10" Padding="14,10" MinWidth="220" Visibility="Collapsed" Canvas.Bottom="0" Canvas.Right="0">
                    <StackPanel Orientation="Horizontal">
                        <Path x:Name="NotificationIcon" Data="M9 12.75L11.25 15L15 9.75M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" Stroke="{StaticResource GoldBrush}" StrokeThickness="2" Stretch="Uniform" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock x:Name="NotificationText" Text="Notification" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Canvas>
        </Grid>
    </Border>
</Window>
